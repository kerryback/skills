# Copy to .env and fill in. Never commit the real .env.
# Narration is written by the Claude Code agent (no Anthropic key needed here);
# the app only calls ElevenLabs for TTS.

# ElevenLabs TTS — voiceover audio (supports account + cloned voices)
ELEVENLABS_API_KEY=

# Per-project deck folders + working files (no database). The launcher points
# this at the project folder, i.e. {project}/.voiceover.
DATA_DIR=./data

# Parallel TTS requests per build (optional; must not exceed your ElevenLabs
# account's concurrent-request limit)
TTS_CONCURRENCY=5

# Parallel ffmpeg segment encodes per build (optional)
VIDEO_CONCURRENCY=4
